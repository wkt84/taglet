{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Taglet",
  "identifier": "dev.taglet.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDZDOEM4NDgwQ0UyOTdGOEIKUldTTGZ5bk9nSVNNYkMxZXI5UnNDem9kN2dKU3VwSUhHZTFYcFpPblhVY2dES040ZTZsdWZ5dTkK",
      "endpoints": [
        "https://github.com/wkt84/taglet/releases/latest/download/latest.json"
      ]
    }
  },
  "app": {
    "windows": [
      {
        "title": "Taglet",
        "width": 1200,
        "height": 780,
        "minWidth": 860,
        "minHeight": 560
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "fileAssociations": [
      {
        "ext": ["dcm", "dicom"],
        "name": "DICOM File",
        "description": "DICOM medical image file",
        "mimeType": "application/dicom",
        "role": "Editor"
      }
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
