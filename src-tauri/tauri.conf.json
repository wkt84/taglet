{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Taglet",
  "version": "0.1.0",
  "identifier": "dev.taglet.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Taglet",
        "width": 1200,
        "height": 780,
        "minWidth": 860,
        "minHeight": 560
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
